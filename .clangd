# =============================================================================
# clangd Configuration for HackRF Mayhem / PortaPack Firmware
# Target: LPC43xx_M0 (ARM Cortex-M0, NXP LPC4330)
# Compiler: arm-none-eabi-g++ (GNU Arm Embedded Toolchain 9.3.1)
# clangd: MSYS2 UCRT64 Clang 18.x
# =============================================================================
#
# IMPORTANT:
# 1. Place this file as ".clangd" (with leading dot!) in project ROOT
# 2. File must be in YAML format (not JSON!)
# 3. clangd uses CLANG compiler for analysis, but queries GCC for includes
# =============================================================================

CompileFlags:
  # ---------------------------------------------------------------------------
  # Compiler Selection - Query GCC driver for system includes
  # CRITICAL: This tells clangd to extract include paths from GCC
  # ---------------------------------------------------------------------------
  Compiler: C:/Program Files (x86)/GNU Arm Embedded Toolchain/9 2020-q2-update/bin/arm-none-eabi-g++.exe

  # ---------------------------------------------------------------------------
  # Core Compiler Flags - Compatible with both GCC and Clang
  # ---------------------------------------------------------------------------
  Add:
    # C++ Standard - GNU extensions have partial Clang support
    - "-std=gnu++20"
    
    # Target Architecture - ARM Cortex-M0 (LPC43xx_M0 subsystem)
    - "-mcpu=cortex-m0"
    - "-mthumb"
    
    # NOTE: FPU is DISABLED for this project (USE_FPU=no in CMake)
    
    # Preprocessor Defines - Target Hardware
    - "-DLPC43XX"
    - "-DLPC43xx_M0"
    - "-D__NEWLIB__"
    - "-DHACKRF_ONE"
    - "-DTOOLCHAIN_GCC"
    - "-DTOOLCHAIN_GCC_ARM"
    - "-D_RANDOM_TCC=0"
    - "-DTHUMB"
    
    # Preprocessor Defines - Board
    - "-DBOARD_PORTAPACK_APPLICATION"
    
    # Preprocessor Defines - ChibiOS
    - "-DCH_KERNEL_MAJOR=3"
    - "-DCH_KERNEL_MINOR=0"
    - "-DCH_USE_REGISTRY=TRUE"
    - "-DCH_USE_WAIT_EXIT=TRUE"
    - "-DCH_USE_HEAP=TRUE"
    - "-DCH_USE_MUTEXES=TRUE"
    - "-DCH_USE_EVENTS=TRUE"
    - "-DCH_USE_MESSAGES=TRUE"
    
    # Disable exceptions and RTTI (embedded constraints)
    - "-fno-exceptions"
    - "-fno-rtti"
    - "-fno-threadsafe-statics"
    
    # Optimization flags for analysis
    - "-Os"
    - "-g"
    - "-ffunction-sections"
    - "-fdata-sections"
    
    # Warnings (compatible with Clang)
    - "-Wall"
    - "-Wextra"
    - "-Wuninitialized"
    - "-Wno-volatile"
    - "-Wno-unused-parameter"
    - "-Wno-missing-field-initializers"
    # Clang-specific: suppress GCC-only warnings
    - "-Wno-unknown-warning-option"
    - "-Wno-gnu-alignof-expression"
    
    # -------------------------------------------------------------------------
    # Project Include Paths - Root and Application
    # -------------------------------------------------------------------------
    - "-I."
    - "-I./firmware"
    - "-I./firmware/application"
    - "-I./firmware/application/apps"
    # CRITICAL FIX: Add EDA module include path
    - "-I./firmware/application/apps/enhanced_drone_analyzer"
    - "-I./firmware/application/ui"
    - "-I./firmware/application/hw"
    - "-I./firmware/application/protocols"
    - "-I./firmware/application/bmps"
    
    # Common and Baseband
    - "-I./firmware/common"
    - "-I./firmware/baseband"
    - "-I./hardware"
    
    # ChibiOS Include Paths
    - "-I./firmware/chibios-portapack/boards/PORTAPACK_APPLICATION"
    - "-I./firmware/chibios-portapack/os/hal/include"
    - "-I./firmware/chibios-portapack/os/rt/include"
    - "-I./firmware/chibios-portapack/os/hal/platforms/LPC43xx_M0"
    - "-I./firmware/chibios-portapack/os/hal/platforms/LPC43xx"
    - "-I./firmware/chibios-portapack/os/ports/GCC/ARMCMx/LPC43xx_M0"
    - "-I./firmware/chibios-portapack/os/common/ports/ARMCMx"
    - "-I./firmware/chibios-portapack/os/various"
    - "-I./firmware/chibios-portapack/os/various/fatfs_bindings"
    
    # HackRF Include Paths
    - "-I./hackrf/firmware/libopencm3/include"
    - "-I./hackrf/firmware/common"
    - "-I./hackrf/firmware"
    
    # External Library Include Paths
    - "-I./firmware/application/external"
    
    # Build Directory Include (for generated files)
    - "-I./firmware/build/application"

  # ---------------------------------------------------------------------------
  # Remove GCC-specific flags that Clang doesn't understand
  # ---------------------------------------------------------------------------
  Remove:
    - "-msse*"
    - "-march=*"
    - "-mfpu=*"
    - "-mfloat-abi=*"
    - "--specs=*"
    - "-flto"
    - "-Weffc++"
    - "-Wno-psabi"

# =============================================================================
# Diagnostics Configuration (SINGLE SECTION - no duplicates!)
# =============================================================================
Diagnostics:
  Suppress:
    - "pp_file_not_found"
    - "missing-prototypes"
    - "strict-prototypes"
    # Suppress errors for GCC-specific constructs
    - "gcc_compat"
  
  UnusedIncludes: Strict
  MissingIncludes: Strict
  
  ClangTidy:
    Add:
      - "bugprone-*"
      - "performance-*"
    Remove:
      - "readability-magic-numbers"
      - "readability-identifier-length"
      - "cppcoreguidelines-pro-type-vararg"
      - "cppcoreguidelines-pro-bounds-pointer-arithmetic"
      - "modernize-*"  # Embedded code often uses older patterns intentionally

# =============================================================================
# Index Settings
# =============================================================================
Index:
  StandardLibrary: No
  Background: Build

# =============================================================================
# Hover and InlayHints
# =============================================================================
Hover:
  ShowAKA: Yes

InlayHints:
  Designators: Yes
  ParameterNames: Yes
  DeducedTypes: Yes

Completion:
  AllScopes: Yes
